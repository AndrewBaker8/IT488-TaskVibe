<Window x:Class="TaskVibe.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskVibe.UI"
        mc:Ignorable="d"
        Title="TaskVibe Management System" Height="500" Width="850">
    <Grid>
        <!-- Define our two main sections: Left for Form, Right for Task List -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <!-- Fixed width for inputs -->
            <ColumnDefinition Width="*"/>
            <!-- Takes up the rest of the screen -->
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Task Entry Form -->
        <StackPanel Grid.Column="0" Margin="15">
            <TextBlock Text="Create New Task" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <!-- Task Title -->
            <TextBlock Text="Task Title" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtTaskTitle" Height="25" Margin="0,0,0,15"/>

            <!-- Due Date -->
            <TextBlock Text="Due Date" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <DatePicker x:Name="DpDueDate" Height="25" Margin="0,0,0,15"/>

            <!-- Status Selection -->
            <TextBlock Text="Initial Status" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbStatus" Height="25" Margin="0,0,0,20" SelectedIndex="0">
                <ComboBoxItem Content="Not Started"/>
                <ComboBoxItem Content="In Process"/>
                <ComboBoxItem Content="Completed"/>
            </ComboBox>

            <!-- Create Task Button -->
            <Button x:Name="BtnCreateTask" Content="Add Task" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>

            <Separator Margin="0,15,0,15"/>

            <!-- Dev Tools: Keep your test button safe right here at the bottom -->
            <TextBlock Text="Developer Utilities" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>
            <Button x:Name="BtnTestConnection" Content="Test DB Connection" Height="30" Click="TestConnection_Click"/>
        </StackPanel>

        <!-- RIGHT PANEL: Main Task Dashboard Grid -->
        <Grid Grid.Column="1" Margin="15">
            <DataGrid x:Name="DgTasks" AutoGenerateColumns="True" AlternatingRowBackground="#F0F0F0" GridLinesVisibility="Horizontal"/>
        </Grid>
    </Grid>
</Window>